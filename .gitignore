# --- Inspiration references (kept locally only) ---
inspirations/*
!inspirations/references.md

# --- Test videos: keep the final assets, ignore regenerable intermediates ---
assets/test-videos/.tmp/
assets/test-videos/segments/

# --- Tauri + Vite + React build artifacts ---
app/node_modules/
app/dist/
app/dist-ssr/
app/.vite/

# --- Tauri Rust build artifacts ---
app/src-tauri/target/
app/src-tauri/gen/schemas/

# --- Editor / OS noise ---
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Bun ---
bun.lockb

# --- TypeScript build cache ---
*.tsbuildinfo
